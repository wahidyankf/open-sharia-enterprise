{
  "name": "ose-grc-contracts",
  "root": "specs/apps/ose-grc/containers/contracts",
  "targets": {
    "lint": {
      "command": "mkdir -p specs/apps/ose-grc/containers/contracts/generated && npx @redocly/cli bundle specs/apps/ose-grc/containers/contracts/openapi.yaml -o specs/apps/ose-grc/containers/contracts/generated/openapi-bundled.yaml && npx @redocly/cli bundle specs/apps/ose-grc/containers/contracts/openapi.yaml -o specs/apps/ose-grc/containers/contracts/generated/openapi-bundled.json && npx @stoplight/spectral-cli lint specs/apps/ose-grc/containers/contracts/generated/openapi-bundled.yaml --ruleset specs/apps/ose-grc/containers/contracts/.spectral.yaml",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.yaml", "!{projectRoot}/generated/**", "!{projectRoot}/examples/**"]
    },
    "bundle": {
      "command": "mkdir -p specs/apps/ose-grc/containers/contracts/generated && npx @redocly/cli bundle specs/apps/ose-grc/containers/contracts/openapi.yaml -o specs/apps/ose-grc/containers/contracts/generated/openapi-bundled.yaml && npx @redocly/cli bundle specs/apps/ose-grc/containers/contracts/openapi.yaml -o specs/apps/ose-grc/containers/contracts/generated/openapi-bundled.json",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.yaml", "!{projectRoot}/generated/**", "!{projectRoot}/examples/**"],
      "outputs": ["{projectRoot}/generated/openapi-bundled.yaml", "{projectRoot}/generated/openapi-bundled.json"]
    },
    "docs": {
      "command": "mkdir -p specs/apps/ose-grc/containers/contracts/generated/docs && npx @redocly/cli bundle specs/apps/ose-grc/containers/contracts/openapi.yaml --remove-unused-components -o specs/apps/ose-grc/containers/contracts/generated/openapi-docs.yaml && npx @redocly/cli build-docs specs/apps/ose-grc/containers/contracts/generated/openapi-docs.yaml -o specs/apps/ose-grc/containers/contracts/generated/docs/index.html",
      "dependsOn": ["bundle"],
      "cache": true,
      "inputs": ["{projectRoot}/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated/docs/"]
    }
  }
}
