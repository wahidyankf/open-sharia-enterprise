{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "demo-fe-ts-remix",
  "sourceRoot": "apps/demo-fe-ts-remix/app",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx react-router dev --port 3301",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx react-router build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/build"],
      "dependsOn": []
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx react-router-serve build/server/index.js",
        "cwd": "{projectRoot}",
        "env": { "PORT": "3301" }
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx react-router typegen && tsc --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --coverage && (cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-fe-ts-remix/coverage/lcov.info 25)",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --project unit",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["type:app", "platform:reactrouter", "lang:ts", "domain:demo-fe"],
  "implicitDependencies": []
}
